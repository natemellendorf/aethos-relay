{
  "name": "canonical-rejections",
  "expectation_mode": "canonical_v1",
  "description": "Canonical server rejects legacy payload forms and emits canonical-only error fields.",
  "relay": {
    "ack_driven_suppression": true
  },
  "clients": [
    {
      "id": "sender",
      "wayfarer_id": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "device_id": "device-sender"
    }
  ],
  "steps": [
    {
      "op": "dial",
      "client": "sender"
    },
    {
      "op": "hello",
      "client": "sender",
      "frame_ref": "frames/client_to_relay/hello.json"
    },
    {
      "op": "expect_frame",
      "client": "sender",
      "frame_ref": "frames/relay_to_client/hello_ok.json",
      "required_fields": [
        "relay_id"
      ]
    },
    {
      "op": "send",
      "client": "sender",
      "frame_ref": "frames/client_to_relay/send.json",
      "to_client": "sender",
      "payload_ref": "payloads/envelope_v1_canonical_example_01.base64.txt"
    },
    {
      "op": "expect_frame",
      "client": "sender",
      "frame_ref": "frames/relay_to_client/error.json",
      "required_fields": [
        "code",
        "message"
      ],
      "forbidden_fields": [
        "msg_id"
      ],
      "field_equals": {
        "message": "invalid payload_b64"
      }
    },
    {
      "op": "send",
      "client": "sender",
      "frame_ref": "frames/client_to_relay/send.json",
      "to_client": "sender",
      "payload_ref": "payloads/envelope_v1_canonical_example_01.b64url.txt"
    },
    {
      "op": "expect_frame",
      "client": "sender",
      "frame_ref": "frames/relay_to_client/message.json",
      "required_fields": [
        "msg_id",
        "from",
        "payload_b64",
        "received_at"
      ],
      "forbidden_fields": [
        "at",
        "expires_at"
      ],
      "field_equals": {
        "from": "$sender.wayfarer_id"
      },
      "capture": {
        "send_msg_id": "msg_id",
        "sent_payload": "payload_b64"
      }
    },
    {
      "op": "expect_frame",
      "client": "sender",
      "frame_ref": "frames/relay_to_client/send_ok.json",
      "required_fields": [
        "msg_id",
        "received_at",
        "expires_at"
      ],
      "forbidden_fields": [
        "at"
      ],
      "field_equals": {
        "msg_id": "$send_msg_id"
      }
    },
    {
      "op": "pull",
      "client": "sender",
      "frame_ref": "frames/client_to_relay/pull.json",
      "limit": 10
    },
    {
      "op": "expect_messages",
      "client": "sender",
      "frame_ref": "frames/relay_to_client/messages.json",
      "count": 1,
      "message_index": 0,
      "message_required_fields": [
        "msg_id",
        "from",
        "payload_b64",
        "received_at"
      ],
      "message_forbidden_fields": [
        "at",
        "expires_at",
        "to",
        "delivered"
      ],
      "message_field_equals": {
        "msg_id": "$send_msg_id",
        "from": "$sender.wayfarer_id"
      },
      "message_payload_equals": "$sent_payload"
    }
  ]
}
